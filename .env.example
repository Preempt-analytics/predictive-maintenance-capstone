# .env.example
#
# WHY THIS FILE EXISTS
# .env is gitignored so credentials are never committed to the repo.
# This file is the committed template — copy it to .env and fill in your values.
#
#   cp .env.example .env
#
# DEMO REPO NOTE
# The demo repo ships .env.demo instead of this file. .env.demo has all values
# pre-filled with the demo account credentials and IS committed to that repo.
# Demo users run `cp .env.demo .env` and docker compose up — no other setup needed.


# ── MLflow / DagsHub ──────────────────────────────────────────────────────────
# The API and monitor load the @production model from DagsHub at startup.
# All three values are required — the container will fail to start without them.
#
# Where to get these:
#   MLFLOW_TRACKING_URI  : DagsHub repo page → Remote → MLflow (copy the URL)
#   MLFLOW_TRACKING_USERNAME : your DagsHub username
#   MLFLOW_TRACKING_PASSWORD : DagsHub → Settings → Access Tokens → New token
MLFLOW_TRACKING_URI=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=


# ── Git identity for the monitor container ────────────────────────────────────
# When the monitor detects drift it runs git commit + git push from inside the
# container. Git requires an author identity before it will create a commit.
# These two variables supply that identity without touching your global git config.
#
# For local development these are optional — the monitor uses your host git config
# when you run it directly (python scripts/monitor.py). They are only required
# when running the monitor as a Docker container.
#
# In the demo repo, .env.demo sets these to the demo bot account.
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=


# ── Git remote URL for the monitor container ──────────────────────────────────
# The monitor container has no .git directory (excluded by .dockerignore).
# docker-compose.yml mounts .git from the host at runtime (see the monitor
# service volumes section), which gives the container the git repo and the
# origin remote. GIT_REMOTE_URL then overrides that remote with a URL that
# embeds a GitHub Personal Access Token so git push authenticates without
# needing SSH keys configured inside the container.
#
# Format: https://<github-pat>@github.com/<org>/<repo>.git
#
# Where to get a PAT:
#   GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
#   Repository access: this repo only
#   Permission: Contents → Read and Write
#
# For local development this is optional — git push uses your host SSH config.
# It is required when running the monitor as a Docker container.
#
# In the demo repo, .env.demo sets this to the demo bot's PAT and repo URL.
GIT_REMOTE_URL=
